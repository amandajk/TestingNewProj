@page "/"
@inject IJSRuntime JS
@using TestingNewProj.Components
<PageTitle>Home</PageTitle>

<!-- ── Hero ── -->
<section class="hero">
    <video autoplay muted loop playsinline class="hero-video">
        <source src="videos/hero.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-content hero-animate">
        <h1 class="hero-title">urlgrey bakery</h1>
        <p class="hero-tagline">some type of tag line</p>
    </div>
</section>

<!-- ── Featured Products ── -->
<section class="section featured">
    <h2 class="section-title fade-up">Our Favorites</h2>
    <p class="section-subtitle fade-up">A taste of what we make</p>
    <HorizontalGallery Items="FeaturedItems" />
</section>

<!-- ── About Blurb ── -->
<section class="section about-blurb">
    <div class="about-blurb-inner">
        <div class="about-blurb-img-wrap fade-up">
            <img src="images/about-placeholder.jpg" alt="About us" class="about-blurb-img" />
        </div>
        <div class="about-blurb-text fade-up">
            <h2>Made with love, baked fresh daily</h2>
            <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit.
                Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
              
            </p>
            <a href="/about" class="btn-outline">Origins</a>
        </div>
    </div>
</section>

@code {
    private List<HorizontalGallery.GalleryItem> FeaturedItems = new()
    {
        new("Vanilla Dream Cake", "images/cake1.jpg", "-normal"),
        new("Chocolate Fudge",    "images/cake2.jpg", "-big"),
        new("Strawberry Layer",   "images/cake3.jpg", "-small"),
        new("Lemon Drizzle",      "images/cake4.jpg", "-normal"),
        new("Carrot Cake",        "images/cake5.jpg", "-big"),
        new("Red Velvet",         "images/cake6.jpg", "-small"),
        new("Vanilla Dream Cake", "images/cake1.jpg", "-normal"),
        new("Chocolate Fudge",    "images/cake2.jpg", "-big"),
        new("Strawberry Layer",   "images/cake3.jpg", "-small"),
        new("Lemon Drizzle",      "images/cake4.jpg", "-normal"),
        new("Carrot Cake",        "images/cake5.jpg", "-big"),
        new("Red Velvet",         "images/cake6.jpg", "-small"),
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("initScrollAnimations");
    }
}

<style>
    .hero {
        position: relative;
        width: 100vw;
        height: 100vh;
        margin-left: calc(-50vw + 50%);
        margin-top: calc(-1 * var(--topbar-h));
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.45) 50%, rgba(0,0,0,0.2) 100%);
        z-index: 1;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
        color: #fff;
        padding: 0 1.5rem;
    }

    .hero-title {
        font-size: clamp(2.5rem, 7vw, 5rem);
        font-weight: 700;
        letter-spacing: 0.04em;
        margin-bottom: 1rem;
    }

    .hero-tagline {
        font-size: clamp(1rem, 2.5vw, 1.4rem);
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        opacity: 0.9;
    }

    .section { padding: 5rem 0; }

    .section-title {
        font-size: 2.2rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: 0.5rem;
        color: var(--text);
    }

    .section-subtitle {
        text-align: center;
        color: var(--text-light);
        font-size: 1rem;
        margin-bottom: 3rem;
        letter-spacing: 0.05em;
    }

    .about-blurb {
        background: var(--blush);
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        padding: 5rem 1.25rem;
    }

    .about-blurb-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .about-blurb-img-wrap {
        aspect-ratio: 4 / 3;
        overflow: hidden;
        border-radius: 4px;
        background: var(--taupe);
    }

    .about-blurb-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .about-blurb-text h2 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 1.25rem;
        line-height: 1.2;
    }

    .about-blurb-text p {
        color: var(--text-light);
        line-height: 1.8;
        margin-bottom: 2rem;
        font-size: 0.95rem;
    }

    .btn-outline {
        display: inline-block;
        border: 1.5px solid var(--brown);
        color: var(--brown);
        padding: 0.7rem 1.75rem;
        font-size: 0.85rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        transition: background 0.2s, color 0.2s;
    }

    .btn-outline:hover {
        background: var(--brown);
        color: #fff;
    }

    @@media (max-width: 768px) {
        .about-blurb-inner {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
    }
</style>
@page "/"
@inject IJSRuntime JS
<PageTitle>Home</PageTitle>

<!-- ── Hero ── -->
<section class="hero">
    <video autoplay muted loop playsinline class="hero-video">
        <source src="videos/hero.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-content hero-animate">
        <h1 class="hero-title">urlgrey bakery</h1>
        <p class="hero-tagline">some type of tag line</p>
    </div>
</section>

<!-- ── Featured Products ── -->
<section class="section featured">
    <h2 class="section-title fade-up">Our Favorites</h2>
    <p class="section-subtitle fade-up">A taste of what we make</p>
    <div class="product-grid">
        @foreach (var item in FeaturedItems)
        {
            <div class="product-card fade-up">
                <div class="product-img-wrap">
                    <img src="@item.Image" alt="@item.Name" class="product-img" />
                </div>
                <div class="product-info">
                    <h3 class="product-name">@item.Name</h3>
                    <p class="product-desc">@item.Description</p>
                    <span class="product-price">@item.Price</span>
                </div>
            </div>
        }
    </div>
</section>

<!-- ── About Blurb ── -->
<section class="section about-blurb">
    <div class="about-blurb-inner">
        <div class="about-blurb-img-wrap fade-up">
            <img src="images/about-placeholder.jpg" alt="About us" class="about-blurb-img" />
        </div>
        <div class="about-blurb-text fade-up">
            <h2>Made with love, baked fresh daily</h2>
            <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit.
                Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                Replace this with your bakery story — who you are, what drives you,
                and why you love what you do.
            </p>
            <a href="/about" class="btn-outline">Our Story</a>
        </div>
    </div>
</section>

@code {
    private List<Product> FeaturedItems = new()
    {
        new("Vanilla Dream Cake", "Light vanilla sponge with buttercream", "$48", "images/cake1.jpg"),
        new("Chocolate Fudge", "Rich chocolate layers with ganache", "$52", "images/cake2.jpg"),
        new("Strawberry Layer", "Fresh strawberries and cream", "$46", "images/cake3.jpg"),
    };

    private record Product(string Name, string Description, string Price, string Image);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("initScrollAnimations");
    }
}

<style>
    /* ── Hero ── */
    .hero {
        position: relative;
        width: 100vw;
        height: 100vh;
        margin-left: calc(-50vw + 50%);
        margin-top: calc(-1 * var(--topbar-h));
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient( to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.45) 50%, rgba(0,0,0,0.2) 100% );
        z-index: 1;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
        color: #fff;
        padding: 0 1.5rem;
    }

    .hero-title {
        font-size: clamp(2.5rem, 7vw, 5rem);
        font-weight: 700;
        letter-spacing: 0.04em;
        margin-bottom: 1rem;
    }

    .hero-tagline {
        font-size: clamp(1rem, 2.5vw, 1.4rem);
        font-weight: 300;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        opacity: 0.9;
    }

    /* ── Sections ── */
    .section {
        padding: 5rem 0;
    }

    .section-title {
        font-size: 2.2rem;
        font-weight: 700;
        text-align: center;
        margin-bottom: 0.5rem;
        color: var(--text);
    }

    .section-subtitle {
        text-align: center;
        color: var(--text-light);
        font-size: 1rem;
        margin-bottom: 3rem;
        letter-spacing: 0.05em;
    }

    /* ── Product Grid ── */
    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 2rem;
    }

    .product-card {
        background: #fff;
        border-radius: 4px;
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.08);
        }

    .product-img-wrap {
        width: 100%;
        aspect-ratio: 1 / 1;
        overflow: hidden;
        background: var(--blush);
    }

    .product-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s;
    }

    .product-card:hover .product-img {
        transform: scale(1.04);
    }

    .product-info {
        padding: 1.25rem;
    }

    .product-name {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 0.4rem;
    }

    .product-desc {
        font-size: 0.88rem;
        color: var(--text-light);
        margin-bottom: 0.75rem;
        line-height: 1.5;
    }

    .product-price {
        font-size: 1rem;
        font-weight: 600;
        color: var(--brown);
    }

    /* ── About Blurb ── */
    .about-blurb {
        background: var(--blush);
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        padding: 5rem 1.25rem;
    }

    .about-blurb-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .about-blurb-img-wrap {
        aspect-ratio: 4 / 3;
        overflow: hidden;
        border-radius: 4px;
        background: var(--taupe);
    }

    .about-blurb-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .about-blurb-text h2 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 1.25rem;
        line-height: 1.2;
    }

    .about-blurb-text p {
        color: var(--text-light);
        line-height: 1.8;
        margin-bottom: 2rem;
        font-size: 0.95rem;
    }

    .btn-outline {
        display: inline-block;
        border: 1.5px solid var(--brown);
        color: var(--brown);
        padding: 0.7rem 1.75rem;
        font-size: 0.85rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        transition: background 0.2s, color 0.2s;
    }

        .btn-outline:hover {
            background: var(--brown);
            color: #fff;
        }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .about-blurb-inner {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
    }
</style>